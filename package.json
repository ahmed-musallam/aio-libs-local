{
  "name": "@musallam/aio-libs-local",
  "version": "0.1.0",
  "description": "Local/in-memory stand-ins for @adobe/aio-lib-files and @adobe/aio-lib-state",
  "keywords": [
    "adobe-io",
    "app-builder",
    "local-dev",
    "openwhisk",
    "testing"
  ],
  "homepage": "https://github.com/ahmed-musallam/aio-libs-local#readme",
  "bugs": {
    "url": "https://github.com/ahmed-musallam/aio-libs-local/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmed-musallam/aio-libs-local.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./files": {
      "types": "./dist/files.d.ts",
      "import": "./dist/files.js",
      "require": "./dist/files.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js",
      "require": "./dist/state.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm run build && vitest run",
    "test:unit": "pnpm run build && vitest run --exclude 'test/bundler/**'",
    "test:bundler": "pnpm run build && vitest run test/bundler",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "mime-types": "3.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/mime-types": "3.0.1",
    "@types/node": "25.9.1",
    "esbuild": "0.28.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "semantic-release": "25.0.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@adobe/aio-lib-files": "*",
    "@adobe/aio-lib-state": "*"
  },
  "peerDependenciesMeta": {
    "@adobe/aio-lib-files": {
      "optional": true
    },
    "@adobe/aio-lib-state": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
